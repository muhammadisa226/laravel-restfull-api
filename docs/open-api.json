        "/api/users": {
            "post": {
                "tags": ["User"],
                "description": "Register New User",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "examples": {
                                "muhammadisa": {
                                    "description": "login user muhammadisa",
                                    "value": {
                                        "username": "muhammadisa",
                                        "password": "rahasia",
                                        "name": "Muhammad Isa"
                                    }
                                }
                            },
                            "schema": {
                                "type": "object",
                                "required": ["username", "password", "name"],
                                "properties": {
                                    "username": {
                                        "type": "string"
                                    },
                                    "password": {
                                        "type": "string"
                                    },
                                    "name": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "400": {
                        "description": "Validation errors",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "ValidationError": {
                                        "description": "Validation Error",
                                        "value": {
                                            "errors": {
                                                "username": [
                                                    "username must not be blank",
                                                    "username min 6 character"
                                                ],
                                                "name": [
                                                    "name must not be blank",
                                                    "name min 6 character"
                                                ]
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "201": {
                        "description": "Success Register User",
                        "content": {
                            "application/json": {
                                "examples": {
                                    "Success": {
                                        "description": "Success Register User",
                                        "value": {
                                            "data": {
                                                "id": 1,
                                                "username": "muhammadisa",
                                                "name": "Muhammad Isa"
                                            }
                                        }
                                    }
                                },
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "id": {
                                                    "type": "number"
                                                },
                                                "username": {
                                                    "type": "string"
                                                },
                                                "name": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
